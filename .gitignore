# macOS
.DS_Store

# Editor
.vscode/
.idea/

# Python build artifacts
__pycache__/
*.pyc

# Local settings (users should not commit these)
.claude/settings.local.json
agents/CLAUDE.md
.claude-plugin/CLAUDE.md

# Runtime / operational data — not for version control
.beads/
.testing/

# epic-swarm scratch state (checkpoints, per-epic-id) — torn down with
# `rm -rf .claude/epic-swarm/<epic-id>` at the end of a run; ignored as a
# backstop for runs that don't reach teardown
.claude/epic-swarm/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
.beads/proxieddb/

# PAS pipeline scratch state (current_task.md, investigation.md,
# test-results.md, logs/<run-id>/checkpoint.json) — overwritten by every
# pipeline run; promote anything worth keeping to a permanent file instead
.pas/

# SkillOpt-Sleep per-run staging (reports, diagnostics, proposed diffs,
# backups) — the accepted output lives in CLAUDE.md and
# skills/skillopt-sleep-learned/SKILL.md instead
.skillopt-sleep/
